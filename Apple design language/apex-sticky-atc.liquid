<!-- ═══════════════════════════════════════════════════════════════
     STARTONER APEX MOBILE STICKY ATC
     A $100M Conversion Module. Displays a persistent "Buy" button
     on mobile devices when the native button scrolls out of view.
     ═══════════════════════════════════════════════════════════════ -->

{% if template.name == 'product' %}
<style>
/* ── APEX OMNI-DEVICE STICKY ATC ── */
#apex-sticky-atc {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100vw;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(40px) saturate(200%);
  -webkit-backdrop-filter: blur(40px) saturate(200%);
  border-top: 1px solid rgba(0,0,0,0.06);
  z-index: 9999999;
  padding: 16px 24px 32px 24px; 
  box-shadow: 0 -12px 32px rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  transform: translateY(120%);
  transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif;
}

#apex-sticky-atc.apex-active {
  transform: translateY(0);
}

/* ── DESKTOP "DYNAMIC ISLAND" MORPH ── */
@media (min-width: 769px) {
  #apex-sticky-atc {
    bottom: 40px;
    left: 50%;
    width: auto;
    min-width: 600px;
    margin-left: -320px; /* Center alignment fallback */
    transform: translate(-50%, 150%);
    border-radius: 100px;
    border: 1px solid rgba(0,0,0,0.04);
    box-shadow: 0 24px 64px rgba(0,0,0,0.1), 0 0 0 1px rgba(255,255,255,0.4) inset;
    padding: 12px 12px 12px 32px;
    gap: 40px;
    background: rgba(255, 255, 255, 0.9);
  }
  #apex-sticky-atc.apex-active {
    transform: translate(-50%, 0);
  }
}

.apex-sticky-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}
@media (min-width: 769px) {
  .apex-sticky-info {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
}

.apex-sticky-title {
  font-size: 13px;
  font-weight: 700;
  color: rgba(29,29,31,0.6);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin: 0 0 2px 0;
  line-height: 1.2;
}
@media (min-width: 769px) {
  .apex-sticky-title { font-size: 15px; margin: 0; }
}

.apex-sticky-price {
  font-size: 18px;
  font-weight: 900;
  color: #1d1d1f;
  margin: 0;
  letter-spacing: -0.02em;
}
@media (min-width: 769px) {
  .apex-sticky-price { font-size: 20px; }
}

.apex-sticky-btn {
  background: #0071e3;
  color: #fff;
  border: none;
  border-radius: 100px;
  padding: 0 28px;
  height: 52px;
  font-size: 16px;
  font-weight: 800;
  cursor: pointer;
  white-space: nowrap;
  box-shadow: 0 12px 24px rgba(0,113,227,0.25);
  transition: all 0.3s;
}
@media (min-width: 769px) {
  .apex-sticky-btn { padding: 0 32px; height: 56px; font-size: 17px; }
}
.apex-sticky-btn:active {
  transform: scale(0.95);
}
</style>

<div id="apex-sticky-atc">
  <div class="apex-sticky-info">
    <p class="apex-sticky-title">{{ product.title }}</p>
    <p id="apex-sticky-price" class="apex-sticky-price">{{ product.price | money }}</p>
  </div>
  <button id="apex-sticky-btn" class="apex-sticky-btn">Agregar</button>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Wait to ensure Shopify's native DOM finishes assembling
  setTimeout(() => {
    // Target Dawn's native "Add To Cart" button
    const nativeButton = document.querySelector('.product-form__submit');
    if (!nativeButton) return;

    const stickyBar = document.getElementById('apex-sticky-atc');
    const stickyPrice = document.getElementById('apex-sticky-price');
    const stickyBtn = document.getElementById('apex-sticky-btn');

    // ── 1. The Remote Detonator ──
    stickyBtn.addEventListener('click', () => {
      // Execute the native button click. This forces Shopify's AJAX cart to open exactly as it normally would.
      nativeButton.click(); 
      
      // UX Micro-interaction: Visual success state
      const originalText = stickyBtn.innerText;
      stickyBtn.innerText = 'Añadido ✓';
      stickyBtn.style.background = '#34c759';
      stickyBtn.style.boxShadow = '0 12px 24px rgba(52, 199, 89, 0.3)';
      setTimeout(() => {
        stickyBtn.innerText = originalText;
        stickyBtn.style.background = '';
        stickyBtn.style.boxShadow = '';
      }, 2000);
    });

    // ── 2. Visibility Tracking ──
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        // Did the native button scroll completely UP past the top of the screen?
        if (!entry.isIntersecting && entry.boundingClientRect.top < 0) {
          stickyBar.classList.add('apex-active');
        } else {
          // If we scroll back up and can see the original button, hide the sticky bar
          stickyBar.classList.remove('apex-active');
        }
      });
    }, { rootMargin: "0px", threshold: 0 });
    
    observer.observe(nativeButton);

    // ── 3. Dynamic Price Cloning ──
    const nativePriceContainer = document.querySelector('.price'); // Dawn's master price wrapper
    if (nativePriceContainer) {
      const updateStickyPrice = () => {
        // Read the currently active price on screen (discounted vs regular)
        const activePriceDOM = nativePriceContainer.querySelector('.price-item--sale') || nativePriceContainer.querySelector('.price-item--regular');
        if (activePriceDOM && activePriceDOM.innerText.trim() !== "") {
          stickyPrice.innerText = activePriceDOM.innerText.trim();
        }
      };
      
      // Initial boot sync
      updateStickyPrice();
      
      // Actively listen for variant changes (user clicks a different size/color) and update sticky price
      const priceObserver = new MutationObserver(updateStickyPrice);
      priceObserver.observe(nativePriceContainer, { childList: true, subtree: true, characterData: true });
    }
  }, 100);
});
</script>
{% endif %}
